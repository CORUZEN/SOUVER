// ═══════════════════════════════════════════════════════════
// SISTEMA OURO VERDE — Prisma Schema
// Fase 1: Fundação — Autenticação, Usuários, RBAC, Auditoria
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// DEPARTAMENTOS
// ──────────────────────────────────────────────
model Department {
  id             String    @id @default(cuid())
  name           String    @unique
  code           String    @unique
  description    String?
  managerUserId  String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  users          User[]
  manager        User?    @relation("DepartmentManager", fields: [managerUserId], references: [id])
  batches        ProductionBatch[]
  nonConformances NonConformance[]
  conversations  Conversation[]

  @@map("departments")
}

// ──────────────────────────────────────────────
// PERFIS DE ACESSO (ROLES)
// ──────────────────────────────────────────────
model Role {
  id                 String    @id @default(cuid())
  name               String    @unique
  code               String    @unique
  description        String?
  requireTwoFactor      Boolean   @default(false) @map("require_two_factor")
  sessionDurationHours  Int?      @map("session_duration_hours")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

// ──────────────────────────────────────────────
// PERMISSÕES
// ──────────────────────────────────────────────
model Permission {
  id          String    @id @default(cuid())
  module      String
  action      String
  code        String    @unique
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

// ──────────────────────────────────────────────
// RELAÇÃO PERFIL <-> PERMISSÕES
// ──────────────────────────────────────────────
model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ──────────────────────────────────────────────
// USUÁRIOS
// ──────────────────────────────────────────────
model User {
  id                 String    @id @default(cuid())
  fullName           String    @map("full_name")
  email              String    @unique
  login              String    @unique
  passwordHash       String    @map("password_hash")
  phone              String?
  avatarUrl          String?   @map("avatar_url")
  departmentId       String?   @map("department_id")
  roleId             String?   @map("role_id")
  status             UserStatus @default(ACTIVE)
  isActive           Boolean   @default(true) @map("is_active")
  twoFactorEnabled   Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret    String?   @map("two_factor_secret")
  sellerCode         String?   @map("seller_code")
  lastLoginAt        DateTime? @map("last_login_at")
  passwordChangedAt  DateTime? @map("password_changed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  department           Department?               @relation(fields: [departmentId], references: [id])
  role                 Role?                     @relation(fields: [roleId], references: [id])
  managedDepartments   Department[]              @relation("DepartmentManager")
  sessions             UserSession[]
  twoFactorCodes       TwoFactorRecoveryCode[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  createdBatches       ProductionBatch[]         @relation("BatchCreator")
  createdEvents        ProductionEvent[]         @relation("EventCreator")
  createdItems         InventoryItem[]           @relation("InventoryCreator")
  createdMovements     InventoryMovement[]       @relation("MovementCreator")
  qualityInspections   QualityRecord[]           @relation("QualityInspector")
  openedNCs            NonConformance[]          @relation("NCOpener")
  assignedNCs          NonConformance[]          @relation("NCAssignee")
  createdConversations Conversation[]            @relation("ConversationCreator")
  conversationParticipations ConversationParticipant[]
  sentMessages         Message[]                 @relation("MessageSender")
  passwordResetTokens  PasswordResetToken[]

  @@index([status, lastLoginAt])
  @@index([departmentId])
  @@index([roleId])
  @@index([twoFactorEnabled, status])
  @@index([lastLoginAt])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ──────────────────────────────────────────────
// SESSÕES DE USUÁRIO
// ──────────────────────────────────────────────
model UserSession {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  ipAddress   String?       @map("ip_address")
  userAgent   String?       @map("user_agent")
  deviceName  String?       @map("device_name")
  startedAt   DateTime      @default(now()) @map("started_at")
  expiresAt   DateTime      @map("expires_at")
  revokedAt   DateTime?     @map("revoked_at")
  status      SessionStatus @default(ACTIVE)

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([startedAt])
  @@map("user_sessions")
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// ──────────────────────────────────────────────
// CÓDIGOS DE RECUPERAÇÃO 2FA
// ──────────────────────────────────────────────
model TwoFactorRecoveryCode {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor_recovery_codes")
}

// ──────────────────────────────────────────────
// TOKENS DE RECUPERAÇÃO DE SENHA
// ──────────────────────────────────────────────
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

// ──────────────────────────────────────────────
// LOGS DE AUDITORIA
// ──────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  module      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  action      String
  oldData     Json?    @map("old_data")
  newData     Json?    @map("new_data")
  description String?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([module, action, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════
// FASE 2 — OPERAÇÃO ESSENCIAL
// ═══════════════════════════════════════════════════════════

// ──────────────────────────────────────────────
// PRODUÇÃO — LOTES
// ──────────────────────────────────────────────
model ProductionBatch {
  id              String              @id @default(cuid())
  batchCode       String              @unique @map("batch_code")
  productName     String              @map("product_name")
  productType     String?             @map("product_type")    // ex: "Café Torrado", "Café Moído"
  productionLine  String?             @map("production_line") // ex: "Linha A", "Linha B"
  shift           ProductionShift     @default(MORNING)
  plannedQty      Decimal?            @map("planned_qty") @db.Decimal(12, 3)
  producedQty     Decimal?            @default(0) @map("produced_qty") @db.Decimal(12, 3)
  unit            String              @default("kg")
  status          ProductionStatus    @default(OPEN)
  startedAt       DateTime?           @map("started_at")
  finishedAt      DateTime?           @map("finished_at")
  notes           String?
  departmentId    String?             @map("department_id")
  createdByUserId String              @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  department      Department?         @relation(fields: [departmentId], references: [id])
  createdBy       User                @relation("BatchCreator", fields: [createdByUserId], references: [id])
  events          ProductionEvent[]
  qualityRecords  QualityRecord[]
  nonConformances NonConformance[]

  @@index([status, createdAt])
  @@index([departmentId, status])
  @@index([shift, status])
  @@index([createdAt])
  @@index([finishedAt])
  @@index([batchCode])
  @@map("production_batches")
}

enum ProductionStatus {
  OPEN
  IN_PROGRESS
  PAUSED
  FINISHED
  CANCELLED
}

enum ProductionShift {
  MORNING   // Manhã
  AFTERNOON // Tarde
  NIGHT     // Noite
}

// ──────────────────────────────────────────────
// PRODUÇÃO — EVENTOS/APONTAMENTOS
// ──────────────────────────────────────────────
model ProductionEvent {
  id          String            @id @default(cuid())
  batchId     String            @map("batch_id")
  type        ProductionEventType
  description String
  quantity    Decimal?          @db.Decimal(12, 3)
  unit        String?
  occurredAt  DateTime          @default(now()) @map("occurred_at")
  createdById String            @map("created_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")

  batch       ProductionBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy   User              @relation("EventCreator", fields: [createdById], references: [id])

  @@index([batchId])
  @@map("production_events")
}

enum ProductionEventType {
  START      // Início do lote
  PROGRESS   // Atualização de quantidade produzida
  PAUSE      // Interrupção/pausa
  RESUME     // Retomada
  WASTE      // Descarte/perda
  FINISH     // Encerramento
  NOTE       // Observação geral
}

// ──────────────────────────────────────────────
// LOGÍSTICA — ITENS DE ESTOQUE
// ──────────────────────────────────────────────
model InventoryItem {
  id              String              @id @default(cuid())
  sku             String              @unique
  name            String
  description     String?
  category        String?
  unit            String              @default("kg")
  currentQty      Decimal             @default(0) @map("current_qty") @db.Decimal(12, 3)
  minQty          Decimal?            @map("min_qty") @db.Decimal(12, 3)  // alerta de estoque mínimo
  maxQty          Decimal?            @map("max_qty") @db.Decimal(12, 3)
  location        String?             // posição no depósito
  isActive        Boolean             @default(true) @map("is_active")
  createdByUserId String              @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  createdBy       User                @relation("InventoryCreator", fields: [createdByUserId], references: [id])
  movements       InventoryMovement[]

  @@index([isActive, name])
  @@index([category])
  @@index([location])
  @@map("inventory_items")
}

// ──────────────────────────────────────────────
// LOGÍSTICA — MOVIMENTAÇÕES
// ──────────────────────────────────────────────
model InventoryMovement {
  id              String              @id @default(cuid())
  itemId          String              @map("item_id")
  type            MovementType
  quantity        Decimal             @db.Decimal(12, 3)
  unit            String
  qtyBefore       Decimal             @map("qty_before") @db.Decimal(12, 3)
  qtyAfter        Decimal             @map("qty_after") @db.Decimal(12, 3)
  reason          String?
  batchRef        String?             @map("batch_ref")  // referência ao lote de produção, se aplicável
  supplier        String?
  documentRef     String?             @map("document_ref")  // NF, ordem de compra, etc.
  movedAt         DateTime            @default(now()) @map("moved_at")
  createdByUserId String              @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at")

  item            InventoryItem       @relation(fields: [itemId], references: [id])
  createdBy       User                @relation("MovementCreator", fields: [createdByUserId], references: [id])

  @@index([itemId, movedAt])
  @@index([type, movedAt])
  @@index([createdByUserId, createdAt])
  @@index([movedAt])
  @@map("inventory_movements")
}

enum MovementType {
  ENTRY       // Entrada
  EXIT        // Saída
  TRANSFER    // Transferência interna
  ADJUSTMENT  // Ajuste de inventário
  RETURN      // Devolução
  WASTE       // Descarte/perda
}

// ──────────────────────────────────────────────
// NOTIFICAÇÕES
// ──────────────────────────────────────────────
model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String
  title     String
  message   String
  module    String?   @map("module")
  link      String?   @map("link")
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, module])
  @@index([userId, isRead, createdAt])
  @@index([createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════
// FASE 3 — QUALIDADE
// ═══════════════════════════════════════════════════════════

// ──────────────────────────────────────────────
// QUALIDADE — REGISTROS DE INSPEÇÃO
// ──────────────────────────────────────────────
model QualityRecord {
  id              String            @id @default(cuid())
  batchId         String?           @map("batch_id")
  inspectionType  String            @map("inspection_type") // ex: "Físico-Química", "Sensorial", "Visual"
  result          InspectionResult  @default(PENDING)
  notes           String?
  inspectedById   String            @map("inspected_by_id")
  inspectedAt     DateTime          @default(now()) @map("inspected_at")
  createdAt       DateTime          @default(now()) @map("created_at")

  batch           ProductionBatch?  @relation(fields: [batchId], references: [id])
  inspectedBy     User              @relation("QualityInspector", fields: [inspectedById], references: [id])
  nonConformances NonConformance[]

  @@index([result, inspectedAt])
  @@index([inspectedAt])
  @@index([batchId, result])
  @@map("quality_records")
}

enum InspectionResult {
  PENDING
  APPROVED
  CONDITIONAL
  REJECTED
}

// ──────────────────────────────────────────────
// QUALIDADE — NÃO CONFORMIDADES
// ──────────────────────────────────────────────
model NonConformance {
  id              String      @id @default(cuid())
  title           String
  description     String
  severity        NCSeverity  @default(MEDIUM)
  status          NCStatus    @default(OPEN)
  batchId         String?     @map("batch_id")
  departmentId    String?     @map("department_id")
  qualityRecordId String?     @map("quality_record_id")
  openedById      String      @map("opened_by_id")
  assignedToId    String?     @map("assigned_to_id")
  openedAt        DateTime    @default(now()) @map("opened_at")
  resolvedAt      DateTime?   @map("resolved_at")
  closedAt        DateTime?   @map("closed_at")
  resolution      String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  batch           ProductionBatch?  @relation(fields: [batchId], references: [id])
  department      Department?       @relation(fields: [departmentId], references: [id])
  qualityRecord   QualityRecord?    @relation(fields: [qualityRecordId], references: [id])
  openedBy        User              @relation("NCOpener", fields: [openedById], references: [id])
  assignedTo      User?             @relation("NCAssignee", fields: [assignedToId], references: [id])

  @@index([status, severity, openedAt])
  @@index([createdAt])
  @@index([severity, status])
  @@index([resolvedAt])
  @@index([departmentId, status])
  @@index([assignedToId, status])
  @@index([openedAt])
  @@map("non_conformances")
}

enum NCSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NCStatus {
  OPEN
  IN_ANALYSIS
  IN_TREATMENT
  RESOLVED
  CLOSED
}

// ═══════════════════════════════════════════════════════════
// FASE 4 — COMUNICAÇÃO INTERNA
// ═══════════════════════════════════════════════════════════

// ──────────────────────────────────────────────
// CONVERSAS
// ──────────────────────────────────────────────
model Conversation {
  id            String           @id @default(cuid())
  type          ConversationType @default(DIRECT)
  name          String?          // usado em grupos/setores
  departmentId  String?          @map("department_id")
  createdById   String           @map("created_by_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  department    Department?      @relation(fields: [departmentId], references: [id])
  createdBy     User             @relation("ConversationCreator", fields: [createdById], references: [id])
  participants  ConversationParticipant[]
  messages      Message[]

  @@map("conversations")
}

enum ConversationType {
  DIRECT  // entre dois usuários
  GROUP   // grupo manual
  DEPARTMENT // canal de setor
}

// ──────────────────────────────────────────────
// PARTICIPANTES DAS CONVERSAS
// ──────────────────────────────────────────────
model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  joinedAt       DateTime     @default(now()) @map("joined_at")
  lastReadAt     DateTime?    @map("last_read_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

// ──────────────────────────────────────────────
// MENSAGENS
// ──────────────────────────────────────────────
model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  content        String
  messageType    MessageType  @default(TEXT)
  editedAt       DateTime?    @map("edited_at")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

enum MessageType {
  TEXT
  SYSTEM  // mensagem de sistema (ex: "usuário entrou")
}

// ═══════════════════════════════════════════════════════════
// FASE 6 — INTEGRAÇÕES EXTERNAS
// ═══════════════════════════════════════════════════════════

// ──────────────────────────────────────────────
// INTEGRAÇÕES
// ──────────────────────────────────────────────
model Integration {
  id               String            @id @default(cuid())
  name             String
  provider         String            // sankhya, erp, api_custom, etc.
  description      String?
  status           IntegrationStatus @default(INACTIVE)
  baseUrl          String?           @map("base_url")
  configEncrypted  String?           @map("config_encrypted")
  lastSyncAt       DateTime?         @map("last_sync_at")
  lastSyncStatus   String?           @map("last_sync_status")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  logs             IntegrationLog[]

  @@index([provider, status])
  @@map("integrations")
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING
}

// ──────────────────────────────────────────────
// CONFIGURAÇÃO DO PAINEL DE METAS
// Stores the full metas workspace config per company scope.
// `scopeKey` = "all" | "1" | "2" (company scope).
// Each month's config lives inside `metaConfigs` JSON.
model MetasConfig {
  id             String   @id @default(cuid())
  scopeKey       String   @unique @map("scope_key") // "all" | "1" | "2"
  metaConfigs    Json     @map("meta_configs")      // Record<monthKey, MetaConfig>
  monthConfigs   Json     @map("month_configs")     // Record<monthKey, MonthConfig>
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedByLogin String?  @map("updated_by_login")

  @@map("metas_config")
}

// ──────────────────────────────────────────────
// LOGS DE INTEGRAÇÃO
// ──────────────────────────────────────────────
model IntegrationLog {
  id              String      @id @default(cuid())
  integrationId   String      @map("integration_id")
  eventType       String      @map("event_type")   // SYNC, TEST, ERROR, IMPORT, EXPORT
  status          String                            // success, error, partial
  message         String?
  requestPayload  Json?       @map("request_payload")
  responsePayload Json?       @map("response_payload")
  durationMs      Int?        @map("duration_ms")
  recordsAffected Int?        @map("records_affected")
  executedAt      DateTime    @default(now()) @map("executed_at")

  integration     Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, executedAt])
  @@index([status, executedAt])
  @@map("integration_logs")
}

// ═══════════════════════════════════════════════════════════
// FASE 7 — LISTAS DE REFERÊNCIA (METAS + FATURAMENTO)
// ═══════════════════════════════════════════════════════════

// ──────────────────────────────────────────────
// METAS — LISTA DE VENDEDORES PERMITIDOS
// ──────────────────────────────────────────────
model MetasSeller {
  id          String   @id @default(cuid())
  code        String?
  partnerCode String?  @map("partner_code")
  name        String   @unique
  active      Boolean  @default(true)
  profileType String   @default("NOVATO") @map("profile_type")
  supervisorCode String? @map("supervisor_code")
  supervisorName String? @map("supervisor_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@index([active])
  @@index([supervisorCode])
  @@map("metas_sellers")
}

// ──────────────────────────────────────────────
// METAS — LISTA DE PRODUTOS PERMITIDOS
// ──────────────────────────────────────────────
model MetasProduct {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  brand       String
  unit        String
  mobility    String   @default("SIM")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("metas_products")
}

// ──────────────────────────────────────────────
// FATURAMENTO — LISTA DE CIDADES
// ──────────────────────────────────────────────
model FaturamentoCity {
  id     String @id @default(cuid())
  code   String @unique
  name   String
  ufCode String @map("uf_code")
  uf     String

  @@index([ufCode])
  @@map("faturamento_cities")
}
