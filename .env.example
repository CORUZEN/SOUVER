# ─────────────────────────────────────────────
# SISTEMA OURO VERDE — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# NUNCA comite o arquivo .env.local no Git
# ─────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────
APP_NAME="Sistema Ouro Verde"
APP_ENV=development
APP_PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Banco de Dados (PostgreSQL — Neon) ─────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── JWT / Sessão ───────────────────────────────
# Gere com: node scripts/generate-secrets.mjs
JWT_SECRET="TROQUE_POR_UMA_CHAVE_SEGURA_COM_MINIMO_64_CHARS"
# JWT_SECRET_LEGACY="CHAVE_ANTIGA_USADA_APENAS_DURANTE_TRANSICAO"
JWT_EXPIRES_IN=8h
SESSION_EXPIRATION_SECONDS=28800

# ── 2FA (TOTP) ─────────────────────────────────
TOTP_APP_NAME="Sistema Ouro Verde"

# ── Ambiente Next.js ──────────────────────────
# LEGADO: o SOUVER não utiliza NextAuth. Pode remover esta variável.
NEXTAUTH_SECRET="TROQUE_POR_UMA_CHAVE_ALEATORIA_SEGURA"
NEXTAUTH_URL=http://localhost:3001

# ── Vercel Cron (proteção de jobs agendados) ───
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="TROQUE_POR_UMA_CHAVE_ALEATORIA_DE_64_CHARS_OU_MAIS"

# Layout de autenticacao (opcional)
# Exemplo: NEXT_PUBLIC_AUTH_LEFT_BG_IMAGE="/images/minha-imagem.jpg"
NEXT_PUBLIC_AUTH_LEFT_BG_IMAGE="/images/auth-enterprise-bg.svg"
