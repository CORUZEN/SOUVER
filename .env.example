# ─────────────────────────────────────────────
# SISTEMA OURO VERDE — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# NUNCA comite o arquivo .env.local no Git
# ─────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────
APP_NAME="Sistema Ouro Verde"
APP_ENV=development
APP_PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Banco de Dados (PostgreSQL — Neon) ─────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── JWT / Sessão ───────────────────────────────
JWT_SECRET="TROQUE_POR_UMA_CHAVE_SEGURA_COM_MINIMO_64_CHARS"
JWT_EXPIRES_IN=8h
SESSION_EXPIRATION_SECONDS=28800

# ── 2FA (TOTP) ─────────────────────────────────
TOTP_APP_NAME="Sistema Ouro Verde"

# ── Ambiente Next.js ──────────────────────────
NEXTAUTH_SECRET="TROQUE_POR_UMA_CHAVE_ALEATORIA_SEGURA"
NEXTAUTH_URL=http://localhost:3001
